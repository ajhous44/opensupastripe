# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Local values come from: supabase status
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Stripe
# Prefer restricted keys where possible. Use test mode locally.
STRIPE_SECRET_KEY=rk_test_or_sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PRICE_ID=
# Optional server-side coupon or promotion configured in your Stripe account
STRIPE_CHECKOUT_COUPON_ID=

# Optional email delivery for contact forms and team invites
RESEND_API_KEY=
RESEND_FROM_EMAIL="My Company <noreply@example.com>"
RESEND_REPLY_TO_EMAILS=hello@example.com
CONTACT_FORM_TO_EMAILS=hello@example.com
SUPPORT_INFO_EMAIL=hello@example.com

# Optional Google One Tap / OAuth UX
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional analytics
NEXT_PUBLIC_GA_ID=

# Optional Sentry monitoring
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Set only in CI/Vercel if uploading source maps
# SENTRY_AUTH_TOKEN=

# Optional Vercel custom-domain management
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
